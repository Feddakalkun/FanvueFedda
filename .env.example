# Fanvue Ultimate Hub local config

# Required for Fanvue OAuth. You can also enter these in the UI under
# Settings > Fanvue Developer Access.
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=

# This must match the redirect URI configured in the Fanvue developer app.
OAUTH_REDIRECT_URI=https://localhost:3001/api/auth/fanvue/callback
OAUTH_ISSUER_BASE_URL=https://auth.fanvue.com

# Fanvue OAuth scopes known to work with the API reference recovered from the
# working backup. Leave unchanged unless your Fanvue app has different grants.
FANVUE_OAUTH_SCOPES=read:self read:chat read:media read:post write:chat write:media write:post

# Optional AI/service keys.
OPENAI_API_KEY=
APIFY_TOKEN=
